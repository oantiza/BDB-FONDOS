rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Función de seguridad para comprobar si es el administrador
    function isAdmin() {
      return request.auth != null && request.auth.token.email == "oantiza@gmail.com";
    }

    // Función de seguridad básica para comprobar si el usuario está autenticado
    function isAuthenticated() {
      return request.auth != null;
    }

    // --- REGLAS PRINCIPALES ---
    
    match /funds_v3/{fundId} {
      // REQUIRE AUTHENTICATION for reads
      allow read: if isAuthenticated();
      // Solo el admin puede escribir/borrar
      allow write, delete: if isAdmin();
    }

    match /historico_vl_v2/{fundId} {
      allow read: if isAuthenticated();
      allow write, delete: if isAdmin();
    }

    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /system_settings/{document=**} {
      // Require authentication to read
      allow read: if isAuthenticated();
      // Solo el administrador puede modificar la configuración del sistema
      allow write: if isAdmin();
    }
    
    match /analysis_results/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // 4.5) Trabajos Administrativos (Jobs)
    match /admin_jobs/{jobId} {
      allow read, write: if request.auth != null && request.auth.token.email == 'oantiza@gmail.com';
    }

    // 4.6) Synthetic Benchmarks
    match /synthetic_benchmarks/{benchmarkId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.email == 'oantiza@gmail.com';
    }

    // 4.7) Reports
    match /reports/{reportId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // 5) Regla por defecto: bloqueo total
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
