# Normalización de fin de línea (auditoría 2026-06-21).
# Evita que ficheros aparezcan como "modificados" por CRLF/LF al mover
# entre Windows y Linux. Texto -> LF en el repo; el checkout local lo adapta.
* text=auto eol=lf

# Scripts específicos de Windows: mantener CRLF
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# Binarios: nunca tocar
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.svg   binary
*.pdf   binary
*.xlsx  binary
*.xls   binary
*.zip   binary
*.7z    binary
*.exe   binary
*.dmg   binary
*.mp4   binary
