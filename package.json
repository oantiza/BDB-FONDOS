{
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "csv-parse": "^6.2.1",
    "dotenv": "^17.4.2",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.0",
    "minimist": "^1.2.8",
    "p-limit": "^7.3.0",
    "pdf-parse": "^1.1.4"
  },
  "name": "bdb-fondos",
  "version": "1.0.0",
  "description": "BDB-FONDOS is a specialized platform for financial portfolio analysis, optimization, and reporting. It leverages Firebase for data and computation, with a React frontend and Python-based cloud functions for quantitative analysis.",
  "main": "scripts/maintenance/audit_derived_unknowns.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "test": "npm run test:gate && npm run test:backend && npm run test:frontend",
    "test:backend": "cd functions_python && python -m pytest -q",
    "test:frontend": "cd frontend && npx vitest run",
    "test:gate": "npm run manual-overrides:gate",
    "manual-overrides:test": "node tests/manual_overrides/test_validate_manual_overrides.js",
    "manual-overrides:validate": "node overrides/validate_manual_overrides.js",
    "manual-overrides:validate:strict": "node overrides/validate_manual_overrides.js --strict --fail-on-warning",
    "manual-overrides:gate": "npm run manual-overrides:test && npm run manual-overrides:validate"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oantiza/BDB-FONDOS.git"
  },
  "keywords": [],
