# BDB-FONDOS Environment Variables
# Copy this file to .env and replace with your actual values.
# NEVER commit the .env file with real values.

# Data provider for prices/fundamentals (EODHD) - used by functions_python/services/config.py
# Get yours at: https://eodhd.com/
EODHD_API_KEY="your-eodhd-api-key-here"

# Google AI (Gemini) API Key
# Get yours at: https://aistudio.google.com/apikey
GEMINI_API_KEY="your-gemini-api-key-here"
