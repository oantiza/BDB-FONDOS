{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://bdb-fondos/schemas/manual_override.schema.json",
  "title": "BDB-FONDOS Manual Override",
  "description": "Contrato institucional para overrides manuales sobre capas canonicas y de compatibilidad temporal.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "override_id",
    "isin",
    "status",
    "author",
    "created_at",
    "reason",
    "operations"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0",
      "description": "Version de contrato del override."
    },
    "override_id": {
      "type": "string",
      "pattern": "^OVR-[0-9]{4}-[0-9]{4,}$",
      "description": "Identificador unico institucional del override."
    },
    "isin": {
      "type": "string",
      "pattern": "^[A-Z]{2}[A-Z0-9]{9}[0-9]$",
      "description": "ISIN del fondo objetivo."
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "approved",
        "rejected",
        "deprecated"
      ],
      "description": "Estado de gobernanza del override."
    },
    "author": {
      "type": "string",
      "minLength": 1
    },
    "approved_by": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "approved_at": {
      "type": "string",
      "format": "date-time"
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "notes": {
      "type": [
        "string",
        "null"
      ]
    },
    "operations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/operation"
      }
    }
  },
  "if": {
    "properties": {
      "status": {
        "const": "approved"
      }
    },
    "required": [
      "status"
    ]
  },
  "then": {
    "required": [
      "approved_by",
      "approved_at"
    ]
  },
  "definitions": {
    "operation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "op",
        "path",
        "reason"
      ],
      "properties": {
        "op": {
          "type": "string",
          "enum": [
            "set",
            "unset",
            "append_unique",
            "remove_values"
          ]
        },
        "path": {
          "type": "string",
          "pattern": "^(classification_v2|portfolio_exposure_v2|eligibility|quality_flags|manual_notes|derived)\\.[A-Za-z0-9_:-]+(\\.[A-Za-z0-9_:-]+)*$",
          "description": "Dot-path permitido dentro de roots institucionales de override."
        },
        "value": {},
        "reason": {
          "type": "string",
          "minLength": 1
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "op": {
                "const": "set"
              }
            },
            "required": [
              "op"
            ]
          },
          "then": {
            "required": [
              "value"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "op": {
                "enum": [
                  "append_unique",
                  "remove_values"
                ]
              }
            },
            "required": [
              "op"
            ]
          },
          "then": {
            "required": [
              "value"
            ],
            "properties": {
              "value": {
                "type": "array"
              }
            }
          }
        }
      ]
    }
  }
}
