rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- REGLAS PRINCIPALES ---

    // --- REGLAS PRINCIPALES ---
    
    match /funds_v3/{fundId} {
      allow read: if true; // Temporarily public for verification
      allow write, delete: if request.auth != null && request.auth.token.email == "oantiza@gmail.com";
    }

    match /historico_vl_v2/{fundId} {
      allow read: if true; // Temporarily public for verification
      allow write, delete: if request.auth != null && request.auth.token.email == "oantiza@gmail.com";
    }

    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /system_settings/{document=**} {
      allow read: if true; // Temporarily public for verification
      allow write: if request.auth != null && request.auth.token.email == "oantiza@gmail.com";
    }
    
    match /analysis_results/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /admin_jobs/{jobId} {
      allow read, write: if request.auth != null && request.auth.token.email == 'oantiza@gmail.com';
    }

    match /synthetic_benchmarks/{benchmarkId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == 'oantiza@gmail.com';
    }

    match /reports/{reportId} {
      allow read: if true; // Temporarily public for verification
      allow write: if request.auth != null && request.auth.token.email == "oantiza@gmail.com";
    }

    // 5) Regla por defecto: bloqueo total
    match /{document=**} {
      allow read: if true; // Temporarily allow for deep verification
      allow write: if false;
    }
  }
}
